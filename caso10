using System;

class Program
{
    static void Main()
    {
        double x = -3;
        double y = 4;

        double distancia = Math.Sqrt(Math.Pow(x, 2) + Math.Pow(y, 2));

        Console.WriteLine("Distancia: " + distancia);
        Console.WriteLine("Valor absoluto de X: " + Math.Abs(x));
        Console.WriteLine("Valor absoluto de Y: " + Math.Abs(y));
    }
}
